# Fail2Ban Configuration - Generated by Ansible
# Date: {{ ansible_date_time.iso8601 }}
# Host: {{ ansible_hostname }}

[DEFAULT]
# Ban hosts for 1 hour
bantime = 3600
# Find time window: 10 minutes
findtime = 600
# Max retry attempts
maxretry = 5
# Backend
backend = auto
# Used by systemd
usedns = warn
# Dest email for ban notifications
destemail = security@company.com
sendername = fail2ban
action = %(action_mwl)s

[sshd]
enabled = true
port = ssh
filter = sshd
logpath = /var/log/secure
backend = %(sshd_backend)s
maxretry = 3
bantime = 7200
findtime = 600

[sshd-ddos]
enabled = true
port = ssh
filter = sshd-ddos
logpath = /var/log/secure
maxretry = 5
findtime = 300

[sshd-aggressive]
enabled = false  # High sensitivity, enable if needed
port = ssh
filter = sshd-aggressive
logpath = /var/log/secure
maxretry = 2
findtime = 300
bantime = 86400  # 24 hours

# Add additional jails as needed
[apache-auth]
enabled = false
port = http,https
filter = apache-auth
logpath = /var/log/httpd/error_log

[apache-badbots]
enabled = false
port = http,https
filter = apache-badbots
logpath = /var/log/httpd/access_log
maxretry = 2