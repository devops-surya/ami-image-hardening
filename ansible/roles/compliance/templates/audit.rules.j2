# CIS Benchmark Audit Rules - {{ cis_version }} {{ cis_profile }}
# Generated by Ansible on {{ ansible_date_time.iso8601 }}

# Monitor sudoers file changes
-w /etc/sudoers -p wa -k sudoers_changes
-w /etc/sudoers.d/ -p wa -k sudoers_changes

# Monitor user and group changes
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity

# Monitor SSH configuration
-w /etc/ssh/sshd_config -p wa -k sshd_config

# Monitor kernel and system modifications
-w /etc/selinux/ -p wa -k selinux_changes
-w /usr/bin/kmod -p x -k module_insertion
-w /etc/modprobe.d/ -p wa -k module_config

# Monitor time changes
-w /etc/localtime -p wa -k time_change
-w /etc/timezone -p wa -k time_change

# Monitor login and logout events
-w /var/log/faillog -p wa -k login_logout_events
-w /var/log/lastlog -p wa -k login_logout_events
-w /var/log/tallylog -p wa -k login_logout_events

# Monitor session initiation
-w /var/run/utmp -p wa -k session_initiation
-w /var/log/wtmp -p wa -k session_initiation
-w /var/log/btmp -p wa -k session_initiation

# Monitor system locale
-w /etc/issue -p wa -k system_locale
-w /etc/issue.net -p wa -k system_locale

# Monitor network configuration
-w /etc/hosts -p wa -k network_config
-w /etc/network/ -p wa -k network_config

# Monitor cron jobs and at
-w /etc/crontab -p wa -k cron_config
-w /etc/cron.hourly/ -p wa -k cron_config
-w /etc/cron.daily/ -p wa -k cron_config
-w /etc/cron.weekly/ -p wa -k cron_config
-w /etc/cron.monthly/ -p wa -k cron_config
-w /etc/cron.d/ -p wa -k cron_config

# Monitor system startup scripts
-w /etc/rc.d/init.d/ -p wa -k init_scripts
-w /etc/init.d/ -p wa -k init_scripts

# Monitor firewall changes
-w /etc/sysconfig/iptables -p wa -k firewall_changes
-w /etc/sysconfig/ip6tables -p wa -k firewall_changes